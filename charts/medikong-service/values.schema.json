{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["app", "image", "container", "service"],
  "properties": {
    "environment": { "type": "string" },
    "app": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "labels": { "type": "object" }
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "replicas": { "type": "integer", "minimum": 1 },
        "annotations": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "strategy": { "type": "object" }
      }
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "container": {
      "type": "object",
      "required": ["port"],
      "properties": {
        "name": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "env": { "type": "array" },
        "envFrom": { "type": "array" },
        "resources": { "type": "object" },
        "readinessProbe": { "type": ["object", "null"] },
        "livenessProbe": { "type": ["object", "null"] }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "rules": { "type": "array" }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": {},
        "annotations": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "objects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "hosts"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "className": { "type": "string" },
              "annotations": { "type": "object" },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "host": { "type": "string" },
                    "paths": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["path", "pathType"],
                        "properties": {
                          "path": { "type": "string", "minLength": 1 },
                          "pathType": { "type": "string", "minLength": 1 }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "hosts": { "type": "array" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "policyTypes": { "type": "array" },
        "ingress": { "type": "array" }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {}
      }
    },
    "hpa": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object" },
        "interval": { "type": "string" },
        "path": { "type": "string" },
        "port": { "type": "string" }
      }
    }
  }
}
