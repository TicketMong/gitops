{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["app", "image", "container", "service"],
  "properties": {
    "environment": { "type": "string" },
    "app": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "labels": { "type": "object" }
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "replicasManaged": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 1 },
        "annotations": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "strategy": { "type": "object" }
      }
    },
    "canary": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "nameSuffix": { "type": "string" },
        "version": { "type": "string" },
        "replicas": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "properties": {
            "tag": { "type": "string" }
          }
        },
        "podLabels": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "container": {
      "type": "object",
      "required": ["port"],
      "properties": {
        "name": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "containerPort"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] }
            }
          }
        },
        "env": { "type": "array" },
        "apiEnv": { "type": "array" },
        "envFrom": { "type": "array" },
        "resources": { "type": "object" },
        "readinessProbe": { "type": ["object", "null"] },
        "livenessProbe": { "type": ["object", "null"] }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "sqlalchemy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "poolSize": { "type": "integer", "minimum": 1 },
            "maxOverflow": { "type": "integer", "minimum": 0 },
            "poolTimeoutSeconds": { "type": "number", "exclusiveMinimum": 0 },
            "poolRecycleSeconds": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "tracing": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "otlpEndpoint": { "type": "string" },
            "excludedUrls": { "type": "string" },
            "pythonFastAPIExcludedUrlsEnabled": { "type": "boolean" }
          }
        }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "rules": { "type": "array" }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": ["string", "integer"] },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "port", "targetPort"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "targetPort": { "type": ["string", "integer"] },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] }
            }
          }
        },
        "annotations": { "type": "object" }
      }
    },
    "migration": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "annotations": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "command": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": { "type": "array" },
        "envFrom": { "type": "array" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "resources": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "objects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "hosts"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "className": { "type": "string" },
              "annotations": { "type": "object" },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "host": { "type": "string" },
                    "paths": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["path", "pathType"],
                        "properties": {
                          "path": { "type": "string", "minLength": 1 },
                          "pathType": { "type": "string", "minLength": 1 }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "hosts": { "type": "array" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "policyTypes": { "type": "array" },
        "ingress": { "type": "array" },
        "egress": { "type": "array" }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {}
      }
    },
    "hpa": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object" },
        "interval": { "type": "string" },
        "path": { "type": "string" },
        "port": { "type": "string" },
        "networkPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string", "minLength": 1 },
            "port": { "type": ["string", "integer", "null"] },
            "extraPorts": {
              "type": "array",
              "items": { "type": ["string", "integer"] }
            }
          }
        }
      }
    }
  }
}
