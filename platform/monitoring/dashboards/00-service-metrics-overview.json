{
  "uid": "medikong-service-metrics-overview",
  "title": "00 Service Metrics Overview",
  "tags": [
    "medikong",
    "services",
    "metrics",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(service_ready, service_environment)",
        "definition": "label_values(service_ready, service_environment)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "1. Request Rate by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 2,
      "title": "2. 5xx Error Rate by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (service_name) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service_name) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "3. p95 Latency by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(http_server_request_duration_seconds_bucket{service_environment=~\"$environment\"}[$__rate_interval])))",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "4. Payment Success Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(payments_total{service_name=\"payment-service\",service_environment=~\"$environment\",result=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(payments_total{service_name=\"payment-service\",service_environment=~\"$environment\"}[$__rate_interval])), 0.001)",
          "legendFormat": "success rate",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "title": "5. Reservation Result and Rejection Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (result) (rate(reservations_total{service_name=\"reservation-service\",service_environment=~\"$environment\"}[$__rate_interval]))",
          "legendFormat": "{{result}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(reservations_total{service_name=\"reservation-service\",service_environment=~\"$environment\",result=\"rejection\"}[$__rate_interval])) / clamp_min(sum(rate(reservations_total{service_name=\"reservation-service\",service_environment=~\"$environment\"}[$__rate_interval])), 0.001)",
          "legendFormat": "rejection rate",
          "range": true,
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "title": "6. Ticket Issue Success and Duplicate Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(tickets_issued_total{service_name=\"ticket-service\",service_environment=~\"$environment\",result=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(tickets_issued_total{service_name=\"ticket-service\",service_environment=~\"$environment\"}[$__rate_interval])), 0.001)",
          "legendFormat": "success rate",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(tickets_issued_total{service_name=\"ticket-service\",service_environment=~\"$environment\",result=\"duplicate\"}[$__rate_interval])) / clamp_min(sum(rate(tickets_issued_total{service_name=\"ticket-service\",service_environment=~\"$environment\"}[$__rate_interval])), 0.001)",
          "legendFormat": "duplicate rate",
          "range": true,
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "title": "7. Event Consume/Publish Failure Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(payment_events_published_total{service_environment=~\"$environment\",result=\"failure\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} publish",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(reservation_events_published_total{service_environment=~\"$environment\",result=\"failure\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} publish",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(ticket_events_published_total{service_environment=~\"$environment\",result=\"failure\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} publish",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(ticket_events_consumed_total{service_environment=~\"$environment\",result=\"failure\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} consume",
          "range": true,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(notification_events_consumed_total{service_environment=~\"$environment\",result=\"failure\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} consume",
          "range": true,
          "refId": "E"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "title": "8. Readiness and Dependency State",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (service_name) (service_ready{service_environment=~\"$environment\"})",
          "legendFormat": "{{service_name}} ready",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (service_name, dependency, dependency_type) (service_dependency_up{service_environment=~\"$environment\"})",
          "legendFormat": "{{service_name}} {{dependency_type}}/{{dependency}}",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (namespace, job) (up{namespace=~\"ticketing-.*|monitoring|observability\"})",
          "legendFormat": "{{namespace}}/{{job}} scrape",
          "range": true,
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
