{
  "uid": "medikong-logs-50-synthetic",
  "title": "Logs 50 - Synthetic",
  "tags": [
    "medikong",
    "logs",
    "loki",
    "observability",
    "synthetic"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 41,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Scenario",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\"}, scenario)",
        "definition": "label_values({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\"}, scenario)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "step",
        "label": "Step",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\"}, step)",
        "definition": "label_values({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\"}, step)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Run Started",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=\"synthetic_run_started\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Run Finished",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=\"synthetic_run_finished\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Run Failed",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=\"synthetic_run_failed\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Synthetic Run State",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (event) (count_over_time({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=~\"synthetic_run_started|synthetic_step|synthetic_run_finished|synthetic_run_failed\" [$__interval]))",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Step Status",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (scenario, step, status) (count_over_time({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=\"synthetic_step\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Failed Step Distribution",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (scenario, step) (count_over_time({k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=\"synthetic_step\" | status=~\"failed|error\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Key Journey Step Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 10
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | step=~\"payment.approve|reservation.create|ticket.list|notification.list\"",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recent Synthetic Run Results",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 9
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=\"synthetic\", k8s_container_name=\"runner\", scenario=~\"$scenario\", step=~\"$step\"} | json | event=~\"synthetic_run_failed|synthetic_run_finished\"",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ]
}
