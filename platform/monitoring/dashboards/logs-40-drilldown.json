{
  "uid": "medikong-logs-40-drilldown",
  "title": "Logs 40 - Drilldown",
  "tags": [
    "medikong",
    "logs",
    "loki",
    "observability",
    "drilldown"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 41,
  "version": 1,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Service Namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(k8s_namespace_name)",
        "definition": "label_values(k8s_namespace_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({k8s_namespace_name=~\"$namespace\"}, service_name)",
        "definition": "label_values({k8s_namespace_name=~\"$namespace\"}, service_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "request_id",
        "label": "Request ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      },
      {
        "name": "trace_id",
        "label": "Trace ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      },
      {
        "name": "business_id",
        "label": "Reservation/Payment/Ticket ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request ID Search",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\", service_name=~\"$service\", k8s_container_name=~\".*-service\"} !~ \"(GET|HEAD) /(health|healthz|readyz|metrics)([ ?]| HTTP)\" | json | request_id=~\"$request_id\" | http_route!~\"/health|/healthz|/metrics|/readyz\"",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
