    },
    {
      "id": 13,
      "title": "Error / Critical / Fatal Logs",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "trace_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open trace in Tempo",
                    "url": "/explore?left={\"datasource\":\"tempo\",\"queries\":[{\"query\":\"${__value.raw}\",\"queryType\":\"traceId\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "request_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Filter this request in Logs 80",
                    "url": "/d/medikong-logs-80-service-trace-detail/logs-80-service-trace-detail?orgId=1&var-environment=$environment&var-namespace=$namespace&var-service=$service&var-route=$route&var-request_id=${__value.raw}&var-trace_id=$trace_id&from=${__from}&to=${__to}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\", service_name=\"$service\", k8s_container_name=~\".*-service\"} | json | severity=~\"ERROR|error|CRITICAL|critical|FATAL|fatal\" | http_route=~\"$route\"",
          "range": true,
          "refId": "A",
          "instant": false
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json",
            "replace": false,
            "keepTime": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "tsNs": true,
              "id": true,
              "trace_flags": true,
              "span_id": true,
              "logger": true,
              "level": true
            },
            "indexByName": {
              "Time": 0,
              "severity": 1,
              "event": 2,
              "http_method": 3,
              "http_route": 4,
              "http_status_code": 5,
              "duration_ms": 6,
              "request_id": 7,
              "trace_id": 8,
              "error_code": 9,
              "message": 10
            },
            "renameByName": {
              "Time": "time"
            }
          }
        }
      ]
    },
    {
      "id": 14,
      "title": "Trace ID Focus Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 24,
        "h": 7
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\", service_name=\"$service\", k8s_container_name=~\".*-service\"} !~ \"(GET|HEAD) /(health|healthz|readyz|metrics)([ ?]| HTTP)\" | json | http_route=~\"$route\" | http_route!~\"/health|/healthz|/metrics|/readyz\" | trace_id=~\"$trace_id\"",
          "range": true,
          "refId": "A"
        }
      ]
