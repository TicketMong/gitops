{
  "uid": "medikong-logs-80-service-trace-detail",
  "title": "Logs 80 - Service Trace Detail",
  "tags": [
    "medikong",
    "logs",
    "loki",
    "tempo",
    "observability",
    "service-detail"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 41,
  "version": 1,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(service_ready, service_environment)",
        "definition": "label_values(service_ready, service_environment)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "namespace",
        "label": "Service Namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(k8s_namespace_name)",
        "definition": "label_values(k8s_namespace_name)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": false,
          "text": "ticketing-payment",
          "value": "ticketing-payment"
        }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({k8s_namespace_name=~\"$namespace\"}, service_name)",
        "definition": "label_values({k8s_namespace_name=~\"$namespace\"}, service_name)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": false,
          "text": "payment-service",
          "value": "payment-service"
        }
      },
      {
        "name": "route",
        "label": "Route Regex",
        "type": "textbox",
        "query": ".*",
        "current": {
          "selected": false,
          "text": ".*",
          "value": ".*"
        }
      },
      {
        "name": "request_id",
        "label": "Request ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      },
      {
        "name": "trace_id",
        "label": "Trace ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "1. Service Health Summary",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Recent Error Logs",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({k8s_namespace_name=~\"$namespace\", service_name=\"$service\", k8s_container_name=~\".*-service\"} | json | severity=~\"ERROR|error|CRITICAL|critical|FATAL|fatal\" | http_route=~\"$route\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
