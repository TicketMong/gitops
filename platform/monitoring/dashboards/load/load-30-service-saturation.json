    {
      "id": 2,
      "title": "Target CPU Cores",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(sum by (namespace, pod, container) (rate(container_cpu_usage_seconds_total{namespace=~\"$service_namespace\",pod=~\"$service_pod\",container!=\"\",container!=\"POD\",pod!=\"\",image!=\"\"}[$__rate_interval])))",
