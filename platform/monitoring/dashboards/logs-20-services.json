        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name, severity) (count_over_time({k8s_namespace_name=~\"$namespace\", service_name=~\"$service\", k8s_container_name=~\".*-service\"} | json | severity=~\"WARN|WARNING|ERROR|warn|warning|error\" [$__interval]))",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
