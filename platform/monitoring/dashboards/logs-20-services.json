          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({k8s_namespace_name=~\"$namespace\", service_name=~\"$service\", k8s_container_name=~\".*-service\"} | json | event=\"http.request.completed\" | http_route!~\"/health|/metrics|/readyz\" | http_status_code=~\"5..\" [$__interval]))",
          "range": true,
