    {
      "id": 7,
      "title": "Available Pod Ratio by Deployment",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.99
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "topk(12, sum by (namespace, deployment) (kube_deployment_status_replicas_available{namespace=~\"$namespace\"}) / clamp_min(sum by (namespace, deployment) (kube_deployment_spec_replicas{namespace=~\"$namespace\"}), 1))",
          "legendFormat": "{{namespace}}/{{deployment}}",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "basic",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
