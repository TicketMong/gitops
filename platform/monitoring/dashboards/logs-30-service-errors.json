  "schemaVersion": 41,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Logs by Service",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "basic",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({k8s_namespace_name=\"ticketing-notification\", service_name=\"notification-service\", k8s_container_name=~\".*-service\"} | json | severity=~\"ERROR|error|CRITICAL|critical|FATAL|fatal\" [$__range])) or label_replace(vector(0), \"service_name\", \"notification-service\", \"\", \"\")",
          "legendFormat": "{{service_name}}",
          "range": false,
          "refId": "A",
          "instant": true
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({k8s_namespace_name=\"ticketing-payment\", service_name=\"payment-service\", k8s_container_name=~\".*-service\"} | json | severity=~\"ERROR|error|CRITICAL|critical|FATAL|fatal\" [$__range])) or label_replace(vector(0), \"service_name\", \"payment-service\", \"\", \"\")",
