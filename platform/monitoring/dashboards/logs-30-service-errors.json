          "expr": "sum by (service_name) (count_over_time({k8s_namespace_name=\"ticketing-ticket\", service_name=\"ticket-service\", k8s_container_name=~\".*-service\"} | json | severity=~\"ERROR|error|CRITICAL|critical|FATAL|fatal\" [$__range])) or label_replace(vector(0), \"service_name\", \"ticket-service\", \"\", \"\")",
