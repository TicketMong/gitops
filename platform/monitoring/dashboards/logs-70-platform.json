      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (k8s_namespace_name, k8s_container_name) (count_over_time({k8s_namespace_name=~\"ticketing-messaging|kafka|data\", k8s_container_name=~\".*(kafka|zookeeper).*\"} | json | severity=~\"WARN|WARNING|ERROR|warn|warning|error\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Platform Component Logs",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 16,
        "y": 7,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (k8s_namespace_name, k8s_container_name) (count_over_time({k8s_namespace_name=~\"$platform_namespace\", k8s_container_name=~\"$platform_container\"} [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
