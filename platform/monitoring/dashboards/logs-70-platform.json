{
  "uid": "medikong-logs-70-platform",
  "title": "Logs 70 - Platform",
  "tags": [
    "medikong",
    "logs",
    "loki",
    "observability",
    "platform"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 41,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "platform_namespace",
        "label": "Platform Namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(k8s_namespace_name)",
        "definition": "label_values(k8s_namespace_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "platform_container",
        "label": "Platform Container",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({k8s_namespace_name=~\"$platform_namespace\"}, k8s_container_name)",
        "definition": "label_values({k8s_namespace_name=~\"$platform_namespace\"}, k8s_container_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Kong 4xx / 5xx",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (status) (count_over_time({k8s_namespace_name=\"kong\"} | json | status=~\"4..|5..\" [$__interval]))",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Collector / Loki Warn Error",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (k8s_container_name, severity) (count_over_time({k8s_namespace_name=\"observability\", k8s_container_name=~\".*(opentelemetry-collector|collector|loki).*\"} | json | severity=~\"WARN|WARNING|ERROR|warn|warning|error\" [$__interval]))",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "DB Warn Error Summary",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (k8s_namespace_name, k8s_container_name) (count_over_time({k8s_namespace_name=~\"data|ticketing-.*\", k8s_container_name=~\".*(postgres|mysql|mariadb|redis).*\"} | json | severity=~\"WARN|WARNING|ERROR|warn|warning|error\" [$__range]))",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka Warn Error Summary",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 8,
        "y": 7,
        "w": 8,
