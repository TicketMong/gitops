    {
      "id": 13,
      "title": "Pod CPU Pressure Top 10",
      "type": "bargauge",
      "description": "CPU PSI from kubelet /metrics/cadvisor, grouped by pod. Uses the pod cgroup series when available and falls back to summed container series.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "topk(10, ((sum by (namespace, pod) (rate(container_pressure_cpu_waiting_seconds_total{namespace=~\"$namespace\",pod=~\"$pod\",container=\"\",image=\"\",pod!=\"\"}[$__rate_interval]))) or (sum by (namespace, pod) (rate(container_pressure_cpu_waiting_seconds_total{namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\",container!=\"POD\",pod!=\"\"}[$__rate_interval])))))",
          "legendFormat": "{{namespace}}/{{pod}}",
