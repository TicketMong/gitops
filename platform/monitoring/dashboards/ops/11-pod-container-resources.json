          "editorMode": "code",
          "expr": "count((sum by (namespace, pod, container) (container_memory_working_set_bytes{namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\",container!=\"POD\",pod!=\"\",image!=\"\"}) / clamp_min(sum by (namespace, pod, container) (kube_pod_container_resource_limits{namespace=~\"$namespace\",pod=~\"$pod\",resource=\"memory\",unit=\"byte\",container!=\"\"}), 1)) > 0.9)",
          "legendFormat": "High Memory Limit Usage",
          "range": false,
