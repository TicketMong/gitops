    {
      "id": 13,
      "title": "Node CPU Requested %",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "((100 * sum by (node) (kube_pod_container_resource_requests{node=~\"$node\",resource=\"cpu\",unit=\"core\"}) / clamp_min(sum by (node) (kube_node_status_allocatable{node=~\"$node\",resource=\"cpu\",unit=\"core\"}), 0.001)) * on (node) group_left(label_role) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))) or ((100 * sum by (node) (kube_pod_container_resource_requests{node=~\"$node\",resource=\"cpu\",unit=\"core\"}) / clamp_min(sum by (node) (kube_node_status_allocatable{node=~\"$node\",resource=\"cpu\",unit=\"core\"}), 0.001)) unless on (node) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\")))",
          "legendFormat": "{{node}} {{label_role}}",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": [

        ]
      },
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "description": "CPU request reservation divided by node allocatable CPU. This is the scheduler budget view, not actual CPU usage."
    },
    {
      "id": 14,
      "title": "Node CPU Remaining",
      "type": "bargauge",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "((sum by (node) (kube_node_status_allocatable{node=~\"$node\",resource=\"cpu\",unit=\"core\"}) - sum by (node) (kube_pod_container_resource_requests{node=~\"$node\",resource=\"cpu\",unit=\"core\"})) * on (node) group_left(label_role) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))) or ((sum by (node) (kube_node_status_allocatable{node=~\"$node\",resource=\"cpu\",unit=\"core\"}) - sum by (node) (kube_pod_container_resource_requests{node=~\"$node\",resource=\"cpu\",unit=\"core\"})) unless on (node) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\")))",
          "legendFormat": "{{node}} {{label_role}}",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        },
        "overrides": [

        ]
      },
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "description": "Remaining allocatable CPU after scheduled pod container requests. Values near zero explain Insufficient cpu scheduling failures."
    },
