          "expr": "topk(10, ((1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"/run.*|/var/lib/kubelet/pods.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"/run.*|/var/lib/kubelet/pods.*\"})) * on (instance) group_left(node) label_replace(node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\") * on (node) group_left(label_role) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))) or (((1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"/run.*|/var/lib/kubelet/pods.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"/run.*|/var/lib/kubelet/pods.*\"})) * on (instance) group_left(node) label_replace(node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\")) unless on (node) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))))",
          "legendFormat": "{{node}} {{label_role}} {{mountpoint}}",
