    {
      "id": 5,
      "title": "Node CPU Utilization",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": [

        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "topk(10, ((1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval]))) * on (instance) group_left(node) label_replace(node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\") * on (node) group_left(label_role) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))) or (((1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval]))) * on (instance) group_left(node) label_replace(node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\")) unless on (node) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))))",
          "legendFormat": "{{node}} {{label_role}}",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "basic",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      }
    },
    {
      "id": 6,
      "title": "Node Memory Utilization",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
