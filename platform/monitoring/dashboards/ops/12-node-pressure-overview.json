          "editorMode": "code",
          "expr": "topk(10, ((1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * on (instance) group_left(node) label_replace(node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\") * on (node) group_left(label_role) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))) or (((1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * on (instance) group_left(node) label_replace(node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\")) unless on (node) (kube_node_labels{node=~\"$node\",label_role=~\".+\"} or label_replace(kube_node_role{node=~\"$node\"}, \"label_role\", \"$1\", \"role\", \"(.+)\"))))",
          "legendFormat": "{{node}} {{label_role}}",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "basic",
