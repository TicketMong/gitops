{
  "uid": "medikong-db-20-instance-resources",
  "title": "DB 20 - Instance Resources",
  "tags": [
    "medikong",
    "database",
    "metrics",
    "resources"
  ],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "db_namespace",
        "label": "DB Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_pod_info{pod=~\".*-db-[0-9]+|notification-db-[0-9]+\"}, namespace)",
        "definition": "label_values(kube_pod_info{pod=~\".*-db-[0-9]+|notification-db-[0-9]+\"}, namespace)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "db_pod",
        "label": "DB Pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_pod_info{namespace=~\"$db_namespace\",pod=~\".*-db-[0-9]+|notification-db-[0-9]+\"}, pod)",
        "definition": "label_values(kube_pod_info{namespace=~\"$db_namespace\",pod=~\".*-db-[0-9]+|notification-db-[0-9]+\"}, pod)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_pod_info{namespace=~\"$db_namespace\",pod=~\"$db_pod\"}, node)",
        "definition": "label_values(kube_pod_info{namespace=~\"$db_namespace\",pod=~\"$db_pod\"}, node)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
